<button
    id="language-toggle"
    type="button"
    class="flex h-8 min-w-14 cursor-pointer items-center justify-center rounded-full border border-main px-2 text-xs font-semibold tracking-wide transition-colors hover:bg-muted"
    aria-label="Switch language to Simplified Chinese"
>
    <span class="lang-en">中文</span>
    <span class="lang-zh">EN</span>
</button>
